# Anthropic (required for chat operations)
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_PRIMARY_MODEL=claude-sonnet-4-6

# Voyage AI (required for embeddings)
VOYAGE_API_KEY=your-voyage-key

# Brain data directory
# Pi: /home/bryan/brain
# Mac (local dev): /Users/bryan/brain
BRAIN_DATA_DIR=/Users/bryan/brain

# ChromaDB
CHROMA_URL=http://localhost:8000
RAG_TOPK=6

# MCP HTTP server
MCP_PORT=3001

# Bearer token. If set, all HTTP requests must include Authorization: Bearer <value>.
# If unset/empty, server runs in OPEN mode (no auth, relies on Funnel URL obscurity).
# Required if any clients support Bearer auth. Leave blank if you only access via
# claude.ai custom connectors (which only support OAuth, not arbitrary Bearer tokens).
MCP_SECRET=

# Allowed Origins for HTTP transport (comma-separated, browser CORS enforcement only)
# Note: MCP clients (Claude Code, iOS) do not send Origin headers and bypass this check.
# The real perimeter defense is MCP_SECRET. Leave unset in dev.
MCP_ALLOWED_ORIGINS=

# Anthropic (required for chat operations)
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_PRIMARY_MODEL=claude-sonnet-4-6

# Voyage AI (required for embeddings)
VOYAGE_API_KEY=your-voyage-key

# Brain data directory
# Pi: /home/<user>/brain
# Mac (local dev): /Users/<user>/brain
BRAIN_DATA_DIR=/Users/<user>/brain

# ChromaDB
CHROMA_URL=http://localhost:8000
RAG_TOPK=6

# MCP HTTP server
MCP_PORT=3001

# Bearer token (REQUIRED for HTTP transport as of build C). iOS + Claude Code send
# Authorization: Bearer <value>. The server REFUSES TO START on --transport http if
# this is unset — open mode was removed (it was the H1 unauth-injection primitive).
MCP_SECRET=

# Allowed Origins for HTTP transport (comma-separated, browser CORS enforcement only)
# Note: MCP clients (Claude Code, iOS) do not send Origin headers and bypass this check.
# The real perimeter defense is MCP_SECRET + OAuth. Leave unset in dev.
MCP_ALLOWED_ORIGINS=

# --- OAuth / DCR (build C — required for HTTP transport) ---
# Public origin of this server, scheme+host only, NO trailing slash, NO path.
# Drives the OAuth issuer + .well-known metadata. Must EXACTLY match the host
# claude.ai reaches (the Tailscale Funnel origin in prod).
#   Local dev:  http://localhost:3001
#   Prod (Pi):  https://<pi-host>.<tailnet>.ts.net
PUBLIC_BASE_URL=http://localhost:3001

# Single-user consent password gating /authorize. claude.ai (or any party that
# DCR-registers) cannot mint a token without a human entering this. Never auto-approve.
OAUTH_AUTHORIZE_PASSWORD=

# Comma-separated EXACT-match allowlist of redirect_uris accepted at DCR /register.
# Empty disables registration. Confirm claude.ai's exact callback in session 2.
#   e.g. https://claude.ai/api/mcp/auth_callback
OAUTH_ALLOWED_REDIRECT_URIS=

# Optional override for the OAuth state dir (clients.json + refresh.json).
# Defaults to ~/.local/state/brain-mcp/oauth/. Used by tests.
# BRAIN_OAUTH_STATE_DIR=
